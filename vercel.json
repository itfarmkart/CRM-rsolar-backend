{
    "version": 2,
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.js"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    },
    "functions": {
        "api/**/*.js": {
            "maxDuration": 300
        },
        "index.js": {
            "maxDuration": 300
        }
    }
}